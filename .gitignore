# ====================
# Vistax AI DocScout — Global .gitignore
# ====================

# --- Dependencies ---
node_modules/
vendor/

# --- Environment files (SECRETS) ---
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# --- Build outputs ---
dist/
build/
frontend/dist/
frontend/public/build/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/storage/logs/*
backend/storage/logs/laravel.log

# --- Laravel Storage (uploaded files) ---
backend/storage/*.key
backend/storage/app/*
!backend/storage/app/.gitkeep
backend/storage/app/documents/*

# --- Laravel Cache ---
backend/storage/framework/cache/*
!backend/storage/framework/cache/.gitkeep
backend/storage/framework/sessions/*
!backend/storage/framework/sessions/.gitkeep
backend/storage/framework/views/*
!backend/storage/framework/views/.gitkeep

# --- Bootstrap cache ---
backend/bootstrap/cache/*
!backend/bootstrap/cache/.gitignore

# --- Database (local development) ---
*.sqlite
*.sqlite-journal

# --- Docker (local overrides) ---
docker-compose.override.yml
