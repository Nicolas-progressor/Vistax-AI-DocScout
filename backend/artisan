#!/usr/bin/env php
<?php

use Illuminate\Foundation\Application;
use Illuminate\Foundation\Console\Kernel;
use Illuminate\Events\Dispatcher;

define('LARAVEL_START', microtime(true));

// 1. Подключаем автозагрузчик Composer
if (file_exists(__DIR__.'/vendor/autoload.php')) {
    require __DIR__.'/vendor/autoload.php';
} elseif (file_exists(__DIR__.'/../vendor/autoload.php')) {
    require __DIR__.'/../vendor/autoload.php';
} else {
    fwrite(STDERR, "Composer autoload file not found.\n");
    exit(1);
}

// 2. Инициализируем приложение
$app = require_once __DIR__.'/bootstrap/app.php';

// 3. Инициализируем ядро Laravel 12 (Передаем ДВА аргумента: $app и Dispatcher)
$kernel = new Kernel($app, $app->make(Dispatcher::class));

// 4. Запускаем консольную команду
$status = $kernel->handle(
    $input = new Symfony\Component\Console\Input\ArgvInput,
    new Symfony\Component\Console\Output\ConsoleOutput
);

$kernel->terminate($input, $status);

exit($status);
